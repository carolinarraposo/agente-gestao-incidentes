GROQ_API_KEY=a_tua_chave_groq

# Chave secreta para assinar os tokens JWT (muda em produção)
JWT_SECRET_KEY=muda-esta-chave-em-producao

# Opcional — só necessário se os repositórios não estiverem na mesma pasta pai
# EXTRACTION_RAW_PATH=../extracao_dados_covilha/data/raw

# Opcional — Cloudflare R2 para armazenamento de ficheiros (usa local se não definido)
# R2_ENDPOINT_URL=https://xxx.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET_NAME=...
# R2_PUBLIC_URL=https://pub-xxx.r2.dev